# BITPAT Environment Variables

# MySQL Database Configuration (for XAMPP/phpMyAdmin)
# Update these values to match your local MySQL setup
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=bitpat
MYSQL_USER=root
MYSQL_PASSWORD=

# Session Secret (generate a random string for production)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# CoinGecko API (optional - for higher rate limits)
# Get your API key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
